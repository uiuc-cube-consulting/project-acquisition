# Copy to .env for local runs. Real values live in GitHub Actions secrets for production.

APOLLO_API_KEY=
ANTHROPIC_API_KEY=

# Either inline JSON or a path to the file
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

# Mailbox the Gmail API will impersonate via domain-wide delegation
IMPERSONATE_EMAIL=projectacquisition@cubeconsulting.org

# Sheet that holds Leads / Drafts / Hot Leads / Suppression tabs
SHEET_ID=

# CUBE alumni database (separate Sheet, optional)
ALUMNI_SHEET_ID=

# CAN-SPAM footer
ORG_NAME=CUBE Consulting
ORG_PHYSICAL_ADDRESS=707 S 4th St, APT 1006A, Champaign IL 61820
UNSUBSCRIBE_MAILTO=unsubscribe@cubeconsulting.org

# Where the daily digest + approval request goes. The approver replies to that
# email ("approve all", "approve 1,3", "skip 2", "none") and the send job reads
# the reply to decide what goes out — no spreadsheet editing needed.
APPROVER_EMAIL=mannat2@illinois.edu
DIGEST_RECIPIENT=mannat2@illinois.edu

# Caps
DAILY_SEND_CAP=10
DAILY_PREPARE_TARGET=15
SEND_INTERVAL_SECONDS=30

# Set to "1" for dry runs (no Apollo cost, no Gmail send)
DRY_RUN=0
